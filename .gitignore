# binaries
/turntable
/bin/

# local config / data
turntable.local.yaml
/turntable.yaml
/data/
# .turntable/ is the per-project runtime dir (web-UI uploads under data/, plus
# dashboard definitions). In turntable's own repo it holds only local dev/test
# artifacts, so it's ignored wholesale — shareable example dashboards belong
# under examples/. (The dashboards feature still writes committable YAML in a
# real user's project; this rule is specific to this repo.)
.turntable/

# generated SQLite demo database (run examples/init_sqlite.sql to recreate)
examples/data/*.db

# go
vendor/
*.test
*.out
coverage.txt

# web UI build tooling (the built dist/ IS committed so `go build` needs no Node)
internal/cli/webui/node_modules/
internal/cli/webui/*.tsbuildinfo

# generated docs (run `make docs`; docs/style.css is the only committed file)
docs/DIALECT.html
docs/DIALECT.pdf
# scratch notes — never committed
LLAMINGTON.md

# python bytecode (sdk/python, plugin scripts)
__pycache__/
*.pyc
